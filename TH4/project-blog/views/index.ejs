<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Blog Của Tôi</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-primary">
    <div class="container">
      <h4 class="text-white mb-0">📝 Blog Cá Nhân</h4>
    </div>
  </nav>

  <div class="container mt-4">
    <h1 class="mb-4">Danh sách bài viết</h1>
    <a href="/blogposts/new" class="btn btn-success mb-4">
      <i class="bi bi-plus-circle"></i> Tạo bài viết mới
    </a>

    <div class="row">
      <% posts.forEach(post => { %>
        <div class="col-md-6 mb-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title"><%= post.title %></h5>
              <p class="card-text text-muted">
                <%= post.body.length > 150 ? post.body.substring(0, 150) + '...' : post.body %>
              </p>
              <a href="/blogposts/<%= post._id %>" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
              <a href="/blogposts/<%= post._id %>/edit" class="btn btn-warning btn-sm">Sửa</a>
              
              <!-- Form xóa -->
              <form action="/blogposts/<%= post._id %>/delete" method="POST" class="d-inline">
                <button type="submit" class="btn btn-danger btn-sm"
                        onclick="return confirm('Bạn có chắc muốn xóa bài này?')">
                  Xóa
                </button>
              </form>
            </div>
            <div class="card-footer text-muted small">
              Ngày tạo: <%= post.createdAt ? post.createdAt.toLocaleDateString('vi-VN') : 'Không có' %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>