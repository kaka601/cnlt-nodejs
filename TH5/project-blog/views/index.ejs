<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Blog - Danh sách bài viết</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="text-primary">📝 Blog của tôi</h1>
      <a href="/new" class="btn btn-primary shadow-sm">+ Thêm bài viết mới</a>
    </div>
    
    <div class="row">
      <% posts.forEach(post => { %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card shadow h-100">
            <div class="card-body">
              <h4 class="card-title"><%= post.title %></h4>
              <% if(post.imageUrl) { %>
                <img src="/uploads/<%= post.imageUrl %>" class="img-fluid mb-2 border rounded" alt="post image" style="max-height: 200px; width: 100%; object-fit: cover;">
              <% } %>
              <p class="card-text text-muted"><%= (post.content || '').substring(0, 120) %>...</p>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
              <div class="text-muted small">
                👤 <%= post.author %> <br>
                📅 <%= post.createdAt.toLocaleDateString('vi-VN') %>
              </div>
              <div class="btn-group">
                <a href="/<%= post._id %>" class="btn btn-sm btn-info text-white">Xem</a>
                <a href="/<%= post._id %>/edit" class="btn btn-sm btn-warning">Sửa</a>
                <form action="/<%= post._id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa bài viết này?')">Xóa</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>